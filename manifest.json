{
  "manifest_version": 3,
  "name": "RTCaaS - Assistente Cognitivo em Tempo Real",
  "version": "0.1.0",
  "description": "Captura audio de videoconferencias e entrega insights taticos em tempo real via IA.",

  "permissions": [
    "activeTab",
    "tabCapture",
    "tabs",
    "sidePanel",
    "storage",
    "downloads",
    "offscreen"
  ],

  "host_permissions": [
    "https://api.groq.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Abrir RTCaaS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
